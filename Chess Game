#  MongoDB DATABASE MANAGER
# ═══════════════════════════════════════════════════════════════════════════════
class DatabaseManager:

    def __init__(self, uri="mongodb://localhost:27017/", db_name="chess_db"):
        self.connected = False
        if not _MONGO_AVAILABLE:
            return
        try:
            self.client = MongoClient(uri, serverSelectionTimeoutMS=2000)
            self.client.server_info()
            self.col = self.client[db_name]["games"]
            self.connected = True
        except Exception as exc:
            print(f"[MongoDB] not available: {exc}")

    # ── CRUD ─────────────────────────────────────────────────────────────────
    def save(self, engine, name=None):
        if not self.connected: return False, "MongoDB not connected"
        doc = {
            "name":     name or f"Game_{datetime.now():%Y%m%d_%H%M%S}",
            "saved_at": datetime.now(),
            "moves": [
                {"from": list(r.from_pos), "to": list(r.to_pos),
                 "promotion": int(r.promotion_piece)}
                for r in engine.move_history
            ],
            "total_moves": len(engine.move_history),
        }
        result = self.col.insert_one(doc)
        return True, str(result.inserted_id)

    def load(self, name):
        if not self.connected: return None, "MongoDB not connected"
        doc = self.col.find_one({"name": name})
        return (doc, "OK") if doc else (None, f"'{name}' not found")

    def list_games(self):
        if not self.connected: return []
        return list(self.col.find({}, {"name":1,"saved_at":1,"total_moves":1,"_id":0}))

    def delete(self, name):
        if not self.connected: return False, "MongoDB not connected"
        res = self.col.delete_one({"name": name})
        return (True, "Deleted") if res.deleted_count else (False, "Not found")


