    # ── board rendering ───────────────────────────────────────────────────────
    def _refresh(self):
        self._draw_board()
        self._update_status()
        self._update_move_list()

    def _draw_board(self):
        c   = self.canvas
        off = 18           # margin for rank/file labels
        sq  = self.SQ
        state = self.engine.state
        c.delete("all")

        # king-in-check square
        check_sq = None
        if self.engine.is_in_check(state, state.is_white_turn):
            kp = self.engine.find_king(state, state.is_white_turn)
            if kp: check_sq = kp

        for r in range(8):
            for col in range(8):
                x0, y0 = off + col*sq, off + r*sq
                x1, y1 = x0+sq, y0+sq

                fill = LIGHT_SQ if (r+col)%2==0 else DARK_SQ
                if   (r,col) == self.selected:        fill = SEL_COLOR
                elif (r,col) in self.legal_targets:   fill = LEGAL_CLR
                elif check_sq and (r,col)==check_sq:  fill = CHECK_CLR

                c.create_rectangle(x0,y0,x1,y1, fill=fill, outline="")

                p = int(state.board[r, col])
                if p != EMPTY:
                    sym  = UNICODE[p]
                    clr  = "#ffffff" if is_white(p) else "#111"
                    cx, cy = x0+sq//2, y0+sq//2
                    # drop shadow (Tkinter does not support alpha hex; use square bg darkened)
                    shadow_clr = "#555555" if (r+col)%2==0 else "#6b4c30"
                    c.create_text(cx+1,cy+2, text=sym, font=("Segoe UI Emoji",28),
                                  fill=shadow_clr, anchor="center")
                    c.create_text(cx, cy,   text=sym, font=("Segoe UI Emoji",28),
                                  fill=clr,          anchor="center")

        # labels
        for r in range(8):
            c.create_text(8, off+r*sq+sq//2, text=str(8-r),
                          font=("Arial",9), fill="#888", anchor="center")
        for col in range(8):
            c.create_text(off+col*sq+sq//2, off+8*sq+9,
                          text=chr(ord('a')+col),
                          font=("Arial",9), fill="#888", anchor="center")

    # ── click handler ─────────────────────────────────────────────────────────
    def _on_click(self, event):
        if self.game_over: return
        off = 18
        col = (event.x - off) // self.SQ
        row = (event.y - off) // self.SQ
        if not in_bounds(row, col): return

        if self.selected:
            if (row, col) in self.legal_targets:
                prom = None
                piece = int(self.engine.state.board[self.selected])
                if (piece==W_PAWN and row==0) or (piece==B_PAWN and row==7):
                    prom = self._ask_promotion()
                self.engine.make_move_if_legal(self.selected, (row,col), prom)
                self.selected = None; self.legal_targets = []
                self._refresh(); self._check_end()
            else:
                p = int(self.engine.state.board[row, col])
                if p!=EMPTY and is_white(p)==self.engine.state.is_white_turn:
                    self._select(row, col)
                else:
                    self.selected=None; self.legal_targets=[]; self._draw_board()
        else:
            p = int(self.engine.state.board[row, col])
            if p==EMPTY or is_white(p)!=self.engine.state.is_white_turn: return
            self._select(row, col)

    def _select(self, r, c):
        self.selected      = (r, c)
        self.legal_targets = self.engine.get_legal_moves_for((r,c))
        self._draw_board()

    def _ask_promotion(self):
        win = tk.Toplevel(self.root); win.title("Promote Pawn")
        win.configure(bg=PAGE_BG); win.grab_set()
        val = tk.StringVar(value="q")
        tk.Label(win, text="Choose promotion:", font=("Arial",11,"bold"),
                 fg=ACCENT, bg=PAGE_BG).pack(pady=10)
        for name, v in (("Queen","q"),("Rook","r"),("Bishop","b"),("Knight","n")):
            tk.Radiobutton(win, text=name, variable=val, value=v,
                           font=("Arial",11), bg=PAGE_BG).pack(anchor="w", padx=20)
        tk.Button(win, text="OK", command=win.destroy,
                  bg=ACCENT, fg="white", font=("Arial",10,"bold"),
                  relief="flat", padx=12).pack(pady=10)
        win.wait_window()
        return val.get()

    def _play_text_move(self):
        if self.game_over: return
        raw = self.move_entry.get().strip().replace(" ","")
        if len(raw) < 4:
            self.status_var.set("Type e2e4 or e2e4q"); return
        fp = alg_to_pos(raw[:2]); tp = alg_to_pos(raw[2:4])
        if not fp or not tp:
            self.status_var.set("Invalid squares."); return
        prom = raw[4].lower() if len(raw)>=5 else None
        if self.engine.make_move_if_legal(fp, tp, prom):
            self.move_entry.delete(0, tk.END)
            self.selected=None; self.legal_targets=[]
            self._refresh(); self._check_end()
        else:
            self.status_var.set("Illegal move.")

    def _undo(self):
        if self.engine.undo_last_move():
            self.selected=None; self.legal_targets=[]; self.game_over=False
            self._refresh()
        else:
            self.status_var.set("Nothing to undo.")

    def _reset(self):
        self.engine.reset()
        self.selected=None; self.legal_targets=[]; self.game_over=False
        self._refresh()

    def _check_end(self):
        st = self.engine.game_status()
        if st in ("checkmate","stalemate"):
            self.game_over = True

    # ── status & move list ────────────────────────────────────────────────────
    def _update_status(self):
        s = self.engine.state
        side = "White" if s.is_white_turn else "Black"
        gst  = self.engine.game_status()
        msgs = {
            "check":     f"⚠ {side} is in CHECK — Move {s.fullmove_number}",
            "checkmate": f"♛ CHECKMATE — {'Black' if s.is_white_turn else 'White'} wins!",
            "stalemate": "🤝 STALEMATE — Draw!",
            "ongoing":   f"{side} to move — Move {s.fullmove_number}",
        }
        self.status_var.set(msgs.get(gst, ""))

    def _update_move_list(self):
        """Uses Pandas DataFrame to format & display the move history."""
        df = self.engine.history_dataframe()
        mt = self.move_text
        mt.configure(state="normal"); mt.delete("1.0", tk.END)
        if df.empty:
            mt.insert(tk.END, "No moves yet.")
        else:
            for num in df["Move #"].unique():
                sub = df[df["Move #"]==num]
                mt.insert(tk.END, f"{num}. ", "nn")
                for _, row in sub.iterrows():
                    tag  = "wm" if row["Side"]=="White" else "bm"
                    text = row["Move"] + ("x" if row["Captured"] else "") + "  "
                    mt.insert(tk.END, text, tag)
                mt.insert(tk.END, "\n")
        mt.see(tk.END); mt.configure(state="disabled")

    # ── statistics window (Matplotlib + Pandas) ───────────────────────────────
    def _show_stats(self):
        df = self.engine.history_dataframe()
        if df.empty:
            messagebox.showinfo("Stats","No moves played yet."); return

        win = tk.Toplevel(self.root)
        win.title("Game Statistics"); win.configure(bg=PAGE_BG)
        win.geometry("860x640")

        fig, axes = plt.subplots(2, 2, figsize=(11,7.5))
        fig.patch.set_facecolor(PAGE_BG)
        fig.suptitle("Game Statistics (Pandas + Matplotlib)",
                     fontsize=13, fontweight="bold", color=ACCENT)

        # ① Piece usage bar chart
        ax = axes[0,0]
        pc = df["Piece"].value_counts()
        pc.plot(kind="bar", ax=ax, color=ACCENT, edgecolor="white", width=0.6)
        ax.set_title("Pieces Moved", color=ACCENT, fontweight="bold"); ax.set_ylabel("Moves")
        ax.tick_params(axis="x", rotation=30)

        # ② Captures pie chart
        ax = axes[0,1]
        cap = df[df["Captured"]!=""].groupby("Side").size()
        if not cap.empty:
            cap.plot(kind="pie", ax=ax, colors=[LIGHT_SQ, DARK_SQ],
                     autopct="%1.0f%%", startangle=140,
                     textprops={"fontsize":10, "color":"#333"})
            ax.set_title("Captures by Side", color=ACCENT, fontweight="bold"); ax.set_ylabel("")
        else:
            ax.text(0.5,0.5,"No captures yet",ha="center",va="center")
            ax.set_title("Captures by Side", color=ACCENT, fontweight="bold")

        # ③ White vs Black stacked bar — NumPy for array maths
        ax = axes[1,0]
        pieces = df["Piece"].unique()
        w_ct = np.array([((df["Piece"]==p)&(df["Side"]=="White")).sum() for p in pieces])
        b_ct = np.array([((df["Piece"]==p)&(df["Side"]=="Black")).sum() for p in pieces])
        x    = np.arange(len(pieces))
        ax.bar(x, w_ct, label="White", color=LIGHT_SQ, edgecolor=ACCENT)
        ax.bar(x, b_ct, bottom=w_ct, label="Black", color=DARK_SQ, edgecolor=ACCENT)
        ax.set_xticks(x); ax.set_xticklabels(pieces, rotation=30)
        ax.set_title("Moves by Piece & Side", color=ACCENT, fontweight="bold")
        ax.legend(fontsize=8)

        # ④ Cumulative moves (line chart via NumPy cumsum)
        ax = axes[1,1]
        wdf = df[df["Side"]=="White"].reset_index(drop=True)
        bdf = df[df["Side"]=="Black"].reset_index(drop=True)
        ax.plot(np.arange(1,len(wdf)+1), np.arange(1,len(wdf)+1),
                label="White", color=ACCENT, marker="o", markersize=3)
        ax.plot(np.arange(1,len(bdf)+1), np.arange(1,len(bdf)+1),
                label="Black", color=DARK_SQ, marker="s", markersize=3)
        ax.set_title("Moves Over Time", color=ACCENT, fontweight="bold")
        ax.set_xlabel("Half-move index"); ax.legend(fontsize=8)

        plt.tight_layout()
        FigureCanvasTkAgg(fig, master=win).get_tk_widget().pack(
            fill=tk.BOTH, expand=True, padx=10, pady=10)

        # Pandas DataFrame table
        tk.Label(win, text="Raw Move Data (Pandas DataFrame)",
                 font=("Arial",9,"bold"), fg=ACCENT, bg=PAGE_BG).pack(anchor="w", padx=12)
        fr = tk.Frame(win); fr.pack(fill="x", padx=12, pady=(0,8))
        cols = list(df.columns)
        tv = ttk.Treeview(fr, columns=cols, show="headings", height=5)
        for col in cols:
            tv.heading(col, text=col); tv.column(col, width=80, anchor="center")
        for _, row in df.iterrows():
            tv.insert("","end", values=list(row))
        tv.pack(fill="x")

    # ── database dialog ───────────────────────────────────────────────────────
    def _show_db(self):
        win = tk.Toplevel(self.root)
        win.title("Database — MongoDB CRUD"); win.configure(bg=PAGE_BG)
        win.geometry("520x500")

        conn_txt = "✔ Connected to MongoDB" if self.db.connected else "✘ MongoDB offline (install + start mongod)"
        tk.Label(win, text=conn_txt, font=("Arial",10,"bold"),
                 fg="green" if self.db.connected else "red", bg=PAGE_BG).pack(pady=8)

        # Save section
        sf = tk.LabelFrame(win, text="Save Current Game", font=("Arial",9,"bold"),
                           fg=ACCENT, bg=PAGE_BG, padx=8, pady=6)
        sf.pack(fill="x", padx=12, pady=4)
        name_v = tk.StringVar(value=f"Game_{datetime.now():%Y%m%d_%H%M%S}")
        tk.Entry(sf, textvariable=name_v, font=("Consolas",10), width=26).pack(side=tk.LEFT, padx=4)

        tree_ref = []   # forward ref

        def do_save():
            ok, msg = self.db.save(self.engine, name_v.get())
            messagebox.showinfo("Save", msg if ok else f"Error: {msg}")
            if tree_ref: _refresh_tree(tree_ref[0])

        tk.Button(sf, text="Save (INSERT)", bg=ACCENT, fg="white",
                  font=("Arial",9,"bold"), relief="flat", padx=8,
                  command=do_save).pack(side=tk.LEFT, padx=4)

        # Game list (READ)
        tk.Label(win, text="Saved Games (MongoDB READ)",
                 font=("Arial",10,"bold"), fg=ACCENT, bg=PAGE_BG).pack(pady=(8,2))
        lf = tk.Frame(win); lf.pack(fill=tk.BOTH, expand=True, padx=12)
        cols = ["Name","Saved At","Moves"]
        tv = ttk.Treeview(lf, columns=cols, show="headings", height=9)
        for c in cols:
            tv.heading(c,text=c); tv.column(c,width=140,anchor="center")
        tv.pack(fill=tk.BOTH, expand=True)
        tree_ref.append(tv)

        def _refresh_tree(t):
            for row in t.get_children(): t.delete(row)
            for g in self.db.list_games():
                t.insert("","end", values=[
                    g.get("name",""), str(g.get("saved_at",""))[:19],
                    g.get("total_moves",0)])

        _refresh_tree(tv)

        bf = tk.Frame(win, bg=PAGE_BG); bf.pack(pady=6)

        def do_load():
            sel = tv.selection()
            if not sel: messagebox.showwarning("Load","Select a game first."); return
            name = tv.item(sel[0])["values"][0]
            doc, msg = self.db.load(name)
            if not doc: messagebox.showerror("Load", msg); return
            self.engine.reset()
            for m in doc["moves"]:
                fr=(m["from"][0],m["from"][1]); to=(m["to"][0],m["to"][1])
                pp = m.get("promotion",0)
                pmap={W_QUEEN:"q",W_ROOK:"r",W_BISHOP:"b",W_KNIGHT:"n",
                      B_QUEEN:"q",B_ROOK:"r",B_BISHOP:"b",B_KNIGHT:"n"}
                self.engine.make_move_if_legal(fr, to, pmap.get(pp))
            self.selected=None; self.legal_targets=[]; self.game_over=False
            self._refresh(); win.destroy()
            messagebox.showinfo("Load",f"Loaded '{name}'")

        def do_delete():
            sel = tv.selection()
            if not sel: return
            name = tv.item(sel[0])["values"][0]
            ok, msg = self.db.delete(name)
            messagebox.showinfo("Delete", msg); _refresh_tree(tv)

        for label, cmd, colour in (
            ("Load (READ)",    do_load,   ACCENT),
            ("Delete (DELETE)", do_delete, "#c0392b"),
            ("Refresh",        lambda: _refresh_tree(tv), "#f5ece4"),
        ):
            fg = "white" if colour != "#f5ece4" else ACCENT
            tk.Button(bf, text=label, bg=colour, fg=fg, font=("Arial",9,"bold"),
                      relief="flat", padx=8, command=cmd).pack(side=tk.LEFT, padx=5)


