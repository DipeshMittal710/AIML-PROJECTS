# ═══════════════════════════════════════════════════════════════════════════════
#  PIECE CONSTANTS  (mirrors C enum)
# ═══════════════════════════════════════════════════════════════════════════════
EMPTY = 0
W_PAWN, W_KNIGHT, W_BISHOP, W_ROOK, W_QUEEN, W_KING = 1, 2, 3, 4, 5, 6
B_PAWN, B_KNIGHT, B_BISHOP, B_ROOK, B_QUEEN, B_KING = 7, 8, 9, 10, 11, 12

UNICODE = {
    W_KING: "♔", W_QUEEN: "♕", W_ROOK: "♖",
    W_BISHOP: "♗", W_KNIGHT: "♘", W_PAWN: "♙",
    B_KING: "♚", B_QUEEN: "♛", B_ROOK: "♜",
    B_BISHOP: "♝", B_KNIGHT: "♞", B_PAWN: "♟",
    EMPTY: " ",
}

PIECE_NAME = {
    W_PAWN: "Pawn",   W_KNIGHT: "Knight", W_BISHOP: "Bishop",
    W_ROOK: "Rook",   W_QUEEN:  "Queen",  W_KING:   "King",
    B_PAWN: "Pawn",   B_KNIGHT: "Knight", B_BISHOP: "Bishop",
    B_ROOK: "Rook",   B_QUEEN:  "Queen",  B_KING:   "King",
}

# colour helpers
def is_white(p):  return 1 <= p <= 6
def is_black(p):  return 7 <= p <= 12
def in_bounds(r, c): return 0 <= r < 8 and 0 <= c < 8

def alg_to_pos(text):
    """'e2' → (row, col) or None"""
    if not text or len(text) < 2: return None
    f = text[0].lower()
    if not ('a' <= f <= 'h'): return None
    if not ('1' <= text[1] <= '8'): return None
    col = ord(f) - ord('a')
    row = 8 - int(text[1])
    return (row, col) if in_bounds(row, col) else None

def pos_to_alg(r, c):
    return chr(ord('a') + c) + str(8 - r)

# ═══════════════════════════════════════════════════════════════════════════════
#  GAME STATE  (NumPy board + metadata)
# ═══════════════════════════════════════════════════════════════════════════════
class GameState:
    """All mutable game data wrapped in one object (easy to deep-copy)."""

    def __init__(self):
        # NumPy 8×8 integer board — key data structure requirement
        self.board = np.zeros((8, 8), dtype=np.int8)
        self.is_white_turn      = True
        self.white_castle_k     = True
        self.white_castle_q     = True
        self.black_castle_k     = True
        self.black_castle_q     = True
        self.en_passant         = None   # (row,col) or None
        self.halfmove_clock     = 0
        self.fullmove_number    = 1

    def copy(self):
        gs = GameState()
        gs.board             = self.board.copy()     # NumPy copy
        gs.is_white_turn     = self.is_white_turn
        gs.white_castle_k    = self.white_castle_k
        gs.white_castle_q    = self.white_castle_q
        gs.black_castle_k    = self.black_castle_k
        gs.black_castle_q    = self.black_castle_q
        gs.en_passant        = self.en_passant
        gs.halfmove_clock    = self.halfmove_clock
        gs.fullmove_number   = self.fullmove_number
        return gs


class MoveRecord:
    """Snapshot of everything needed to undo a move."""

    __slots__ = (
        "from_pos", "to_pos", "moved_piece", "captured_piece",
        "prev_white_castle_k", "prev_white_castle_q",
        "prev_black_castle_k", "prev_black_castle_q",
        "prev_en_passant", "prev_halfmove", "prev_fullmove",
        "promotion_piece",
    )

    def __init__(self):
        self.from_pos = self.to_pos = None
        self.moved_piece = self.captured_piece = EMPTY
        self.prev_white_castle_k = self.prev_white_castle_q = True
        self.prev_black_castle_k = self.prev_black_castle_q = True
        self.prev_en_passant     = None
        self.prev_halfmove       = 0
        self.prev_fullmove       = 1
        self.promotion_piece     = EMPTY

# ═══════════════════════════════════════════════════════════════════════════════
#  CHESS ENGINE  (direct port of the C logic)
# ═══════════════════════════════════════════════════════════════════════════════
class ChessEngine:

    INIT_BOARD = [
        [B_ROOK, B_KNIGHT, B_BISHOP, B_QUEEN, B_KING, B_BISHOP, B_KNIGHT, B_ROOK],
        [B_PAWN] * 8,
        [EMPTY]  * 8, [EMPTY] * 8, [EMPTY] * 8, [EMPTY] * 8,
        [W_PAWN] * 8,
        [W_ROOK, W_KNIGHT, W_BISHOP, W_QUEEN, W_KING, W_BISHOP, W_KNIGHT, W_ROOK],
    ]

    def __init__(self):
        self.state        = GameState()
        self.move_history = []          # list[MoveRecord]
        self._init_board()

    # ── setup ────────────────────────────────────────────────────────────────
    def _init_board(self):
        for r, row in enumerate(self.INIT_BOARD):
            for c, p in enumerate(row):
                self.state.board[r, c] = p

    def reset(self):
        self.state        = GameState()
        self.move_history = []
        self._init_board()

    # ── attack detection ─────────────────────────────────────────────────────
    def square_attacked_by(self, state, tr, tc, by_white):
        board = state.board

        # Pawn attacks
        if by_white:
            for dc in (-1, 1):
                r2, c2 = tr - 1, tc + dc
                if in_bounds(r2, c2) and board[r2, c2] == W_PAWN:
                    return True
        else:
            for dc in (-1, 1):
                r2, c2 = tr + 1, tc + dc
                if in_bounds(r2, c2) and board[r2, c2] == B_PAWN:
                    return True

        # Knights — NumPy: use vectorised check list
        knight = W_KNIGHT if by_white else B_KNIGHT
        for dr, dc in ((-2,-1),(-2,1),(-1,-2),(-1,2),(1,-2),(1,2),(2,-1),(2,1)):
            r2, c2 = tr + dr, tc + dc
            if in_bounds(r2, c2) and board[r2, c2] == knight:
                return True

        rook   = W_ROOK   if by_white else B_ROOK
        queen  = W_QUEEN  if by_white else B_QUEEN
        bishop = W_BISHOP if by_white else B_BISHOP
        king   = W_KING   if by_white else B_KING

        # Orthogonal (rook / queen / king-1-step)
        for dr, dc in ((-1,0),(1,0),(0,-1),(0,1)):
            r2, c2 = tr + dr, tc + dc
            while in_bounds(r2, c2):
                p = board[r2, c2]
                if p != EMPTY:
                    if p in (rook, queen): return True
                    if p == king and r2 == tr+dr and c2 == tc+dc: return True
                    break
                r2 += dr; c2 += dc

        # Diagonal (bishop / queen / king-1-step)
        for dr, dc in ((-1,-1),(-1,1),(1,-1),(1,1)):
            r2, c2 = tr + dr, tc + dc
            while in_bounds(r2, c2):
                p = board[r2, c2]
                if p != EMPTY:
                    if p in (bishop, queen): return True
                    if p == king and r2 == tr+dr and c2 == tc+dc: return True
                    break
                r2 += dr; c2 += dc

        return False

    def find_king(self, state, white):
        king = W_KING if white else B_KING
        pos = np.argwhere(state.board == king)   # NumPy search
        return tuple(pos[0]) if len(pos) else None

    def is_in_check(self, state, white):
        kp = self.find_king(state, white)
        if kp is None: return False
        return self.square_attacked_by(state, kp[0], kp[1], not white)

    # ── pseudo-legal move check (mirrors C is_pseudo_legal_move) ─────────────
    def is_pseudo_legal(self, state, from_pos, to_pos, promotion=None):
        fr, fc = from_pos; tr, tc = to_pos
        if not (in_bounds(fr, fc) and in_bounds(tr, tc)): return False
        piece = int(state.board[fr, fc])
        if piece == EMPTY: return False
        moving_white = is_white(piece)
        if state.is_white_turn != moving_white: return False
        target = int(state.board[tr, tc])
        if target != EMPTY and is_white(target) == moving_white: return False

        dr, dc = tr - fr, tc - fc
        adr, adc = abs(dr), abs(dc)

        # ── Pawn ──────────────────────────────────────────────────────────────
        if piece in (W_PAWN, B_PAWN):
            direction = -1 if piece == W_PAWN else 1
            if dc == 0:
                if dr == direction:
                    if state.board[tr, tc] != EMPTY: return False
                    if piece == W_PAWN and tr == 0 and not promotion: return False
                    if piece == B_PAWN and tr == 7 and not promotion: return False
                    return True
                # double push
                if piece == W_PAWN and fr == 6 and dr == -2:
                    return (state.board[fr-1, fc] == EMPTY and
                            state.board[tr,  tc]  == EMPTY)
                if piece == B_PAWN and fr == 1 and dr == 2:
                    return (state.board[fr+1, fc] == EMPTY and
                            state.board[tr,  tc]  == EMPTY)
                return False
            if adc == 1 and dr == direction:
                if state.board[tr, tc] != EMPTY: return True
                ep = state.en_passant
                if ep and (tr, tc) == ep: return True
                return False
            return False

        # ── Knight ────────────────────────────────────────────────────────────
        if piece in (W_KNIGHT, B_KNIGHT):
            return (adr == 2 and adc == 1) or (adr == 1 and adc == 2)

        # ── King ──────────────────────────────────────────────────────────────
        if piece in (W_KING, B_KING):
            if adr <= 1 and adc <= 1: return True
            if dr == 0 and adc == 2:
                if piece == W_KING and fr == 7 and fc == 4:
                    if dc == 2:  return (state.white_castle_k and
                                         state.board[7,5]==EMPTY and state.board[7,6]==EMPTY and
                                         state.board[7,7]==W_ROOK)
                    if dc == -2: return (state.white_castle_q and
                                         state.board[7,3]==EMPTY and state.board[7,2]==EMPTY and
                                         state.board[7,1]==EMPTY and state.board[7,0]==W_ROOK)
                if piece == B_KING and fr == 0 and fc == 4:
                    if dc == 2:  return (state.black_castle_k and
                                         state.board[0,5]==EMPTY and state.board[0,6]==EMPTY and
                                         state.board[0,7]==B_ROOK)
                    if dc == -2: return (state.black_castle_q and
                                         state.board[0,3]==EMPTY and state.board[0,2]==EMPTY and
                                         state.board[0,1]==EMPTY and state.board[0,0]==B_ROOK)
            return False

        # ── Sliding (Rook / Bishop / Queen) ───────────────────────────────────
        if piece in (W_ROOK,B_ROOK,W_BISHOP,B_BISHOP,W_QUEEN,B_QUEEN):
            if dr == 0 and dc == 0: return False
            rook_like   = piece in (W_ROOK,B_ROOK,W_QUEEN,B_QUEEN)  and (dr==0 or dc==0)
            bishop_like = piece in (W_BISHOP,B_BISHOP,W_QUEEN,B_QUEEN) and adr==adc
            if not rook_like and not bishop_like: return False
            sr = 0 if dr==0 else (1 if dr>0 else -1)
            sc = 0 if dc==0 else (1 if dc>0 else -1)
            r2, c2 = fr+sr, fc+sc
            while (r2, c2) != (tr, tc):
                if not in_bounds(r2, c2) or state.board[r2, c2] != EMPTY: return False
                r2 += sr; c2 += sc
            return True

        return False

    # ── perform move (mutates state) ─────────────────────────────────────────
    def _perform_move(self, state, from_pos, to_pos, promotion=None):
        rec = MoveRecord()
        fr, fc = from_pos; tr, tc = to_pos
        rec.from_pos  = from_pos;  rec.to_pos  = to_pos
        rec.moved_piece   = int(state.board[fr, fc])
        rec.captured_piece= int(state.board[tr, tc])
        rec.prev_white_castle_k = state.white_castle_k
        rec.prev_white_castle_q = state.white_castle_q
        rec.prev_black_castle_k = state.black_castle_k
        rec.prev_black_castle_q = state.black_castle_q
        rec.prev_en_passant  = state.en_passant
        rec.prev_halfmove    = state.halfmove_clock
        rec.prev_fullmove    = state.fullmove_number

        piece = rec.moved_piece

        # halfmove clock
        if piece in (W_PAWN, B_PAWN) or state.board[tr, tc] != EMPTY:
            state.halfmove_clock = 0
        else:
            state.halfmove_clock += 1

        # en-passant capture
        if (piece in (W_PAWN, B_PAWN) and state.en_passant and
                (tr, tc) == state.en_passant and state.board[tr, tc] == EMPTY):
            capr = tr + (1 if piece == W_PAWN else -1)
            rec.captured_piece = int(state.board[capr, tc])
            state.board[capr, tc] = EMPTY

        state.en_passant = None
        state.board[tr, tc] = state.board[fr, fc]
        state.board[fr, fc] = EMPTY

        # new en-passant target
        if piece == W_PAWN and fr == 6 and tr == 4:
            state.en_passant = (5, fc)
        elif piece == B_PAWN and fr == 1 and tr == 3:
            state.en_passant = (2, fc)

        # castling rook move
        if piece in (W_KING, B_KING) and fr == tr and abs(tc-fc) == 2:
            if tc == 6:
                state.board[tr, 5] = state.board[tr, 7]; state.board[tr, 7] = EMPTY
            elif tc == 2:
                state.board[tr, 3] = state.board[tr, 0]; state.board[tr, 0] = EMPTY

        # promotion
        if (piece == W_PAWN and tr == 0) or (piece == B_PAWN and tr == 7):
            pmap = {'q': W_QUEEN if is_white(piece) else B_QUEEN,
                    'r': W_ROOK  if is_white(piece) else B_ROOK,
                    'b': W_BISHOP if is_white(piece) else B_BISHOP,
                    'n': W_KNIGHT if is_white(piece) else B_KNIGHT}
            prom = pmap.get(promotion, W_QUEEN if is_white(piece) else B_QUEEN)
            state.board[tr, tc]   = prom
            rec.promotion_piece   = prom

        # castling rights
        if piece == W_KING: state.white_castle_k = state.white_castle_q = False
        if piece == B_KING: state.black_castle_k = state.black_castle_q = False
        for (rr, cc), attr in (
            ((7,0),'white_castle_q'),((7,7),'white_castle_k'),
            ((0,0),'black_castle_q'),((0,7),'black_castle_k'),
        ):
            if (fr,fc)==(rr,cc) or (tr,tc)==(rr,cc):
                setattr(state, attr, False)

        if not state.is_white_turn: state.fullmove_number += 1
        state.is_white_turn = not state.is_white_turn
        return rec

    # ── public API ───────────────────────────────────────────────────────────
    def make_move_if_legal(self, from_pos, to_pos, promotion=None):
        if not self.is_pseudo_legal(self.state, from_pos, to_pos, promotion):
            return False
        test = self.state.copy()
        self._perform_move(test, from_pos, to_pos, promotion)
        if self.is_in_check(test, is_white(int(self.state.board[from_pos]))):
            return False
        rec = self._perform_move(self.state, from_pos, to_pos, promotion)
        self.move_history.append(rec)
        return True

    def undo_last_move(self):
        if not self.move_history: return False
        rec   = self.move_history.pop()
        state = self.state
        state.is_white_turn    = not state.is_white_turn
        state.fullmove_number  = rec.prev_fullmove
        state.halfmove_clock   = rec.prev_halfmove
        fr, fc = rec.from_pos; tr, tc = rec.to_pos
        state.board[fr, fc]    = rec.moved_piece
        state.board[tr, tc]    = rec.captured_piece
        if rec.moved_piece in (W_KING,B_KING) and fr==tr and abs(tc-fc)==2:
            if tc==6: state.board[tr,7]=state.board[tr,5]; state.board[tr,5]=EMPTY
            elif tc==2: state.board[tr,0]=state.board[tr,3]; state.board[tr,3]=EMPTY
        if rec.promotion_piece != EMPTY:
            state.board[fr, fc] = W_PAWN if is_white(rec.moved_piece) else B_PAWN
        state.white_castle_k = rec.prev_white_castle_k
        state.white_castle_q = rec.prev_white_castle_q
        state.black_castle_k = rec.prev_black_castle_k
        state.black_castle_q = rec.prev_black_castle_q
        state.en_passant     = rec.prev_en_passant
        return True

    def get_legal_moves_for(self, from_pos):
        fr, fc = from_pos
        piece  = int(self.state.board[fr, fc])
        if piece == EMPTY or is_white(piece) != self.state.is_white_turn: return []
        moves = []
        for tr in range(8):
            for tc in range(8):
                prom = None
                if piece == W_PAWN and tr == 0: prom = 'q'
                if piece == B_PAWN and tr == 7: prom = 'q'
                if not self.is_pseudo_legal(self.state, (fr,fc), (tr,tc), prom): continue
                test = self.state.copy()
                self._perform_move(test, (fr,fc), (tr,tc), prom)
                if not self.is_in_check(test, is_white(piece)):
                    moves.append((tr, tc))
        return moves

    def side_has_legal_move(self, white):
        saved = self.state.is_white_turn
        self.state.is_white_turn = white
        result = False
        positions = np.argwhere(                          # NumPy: find all pieces
            (self.state.board >= 1) & (self.state.board <= 6)
            if white else
            (self.state.board >= 7) & (self.state.board <= 12)
        )
        for fr, fc in positions:
            piece = int(self.state.board[fr, fc])
            for tr in range(8):
                for tc in range(8):
                    prom = None
                    if piece == W_PAWN and tr==0: prom='q'
                    if piece == B_PAWN and tr==7: prom='q'
                    if not self.is_pseudo_legal(self.state,(fr,fc),(tr,tc),prom): continue
                    test = self.state.copy()
                    self._perform_move(test,(fr,fc),(tr,tc),prom)
                    if not self.is_in_check(test, white):
                        result = True; break
                if result: break
            if result: break
        self.state.is_white_turn = saved
        return result

    def game_status(self):
        white   = self.state.is_white_turn
        in_chk  = self.is_in_check(self.state, white)
        has_mv  = self.side_has_legal_move(white)
        if in_chk and not has_mv: return 'checkmate'
        if not in_chk and not has_mv: return 'stalemate'
        if in_chk: return 'check'
        return 'ongoing'

    # ── Pandas: move history DataFrame ───────────────────────────────────────
    def history_dataframe(self):
        rows = []
        for i, rec in enumerate(self.move_history):
            rows.append({
                "Move #":    i // 2 + 1,
                "Side":      "White" if i % 2 == 0 else "Black",
                "Move":      pos_to_alg(*rec.from_pos) + pos_to_alg(*rec.to_pos),
                "Piece":     PIECE_NAME.get(rec.moved_piece, "?"),
                "From":      pos_to_alg(*rec.from_pos),
                "To":        pos_to_alg(*rec.to_pos),
                "Captured":  PIECE_NAME.get(rec.captured_piece, "") if rec.captured_piece else "",
                "Promotion": UNICODE.get(rec.promotion_piece, "") if rec.promotion_piece else "",
            })
        return pd.DataFrame(rows)


