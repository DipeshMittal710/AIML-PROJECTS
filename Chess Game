class ChessGUI:

    SQ = 72  # square size px

    def __init__(self, root):
        self.root    = root
        self.root.title("Chess — Python Edition")
        self.root.configure(bg=PAGE_BG)

        self.engine  = ChessEngine()
        self.db      = DatabaseManager()

        self.selected      = None
        self.legal_targets = []
        self.game_over     = False

        self._build_ui()
        self._refresh()

    # ── UI construction ───────────────────────────────────────────────────────
    def _build_ui(self):
        # left guide
        left = tk.Frame(self.root, bg=PAGE_BG, width=220)
        left.pack(side=tk.LEFT, fill=tk.Y, padx=(10,0), pady=10)
        left.pack_propagate(False)
        self._build_guide(left)

        # centre board
        centre = tk.Frame(self.root, bg=PAGE_BG)
        centre.pack(side=tk.LEFT, padx=16, pady=10)

        tk.Label(centre, text="♔  Chess Board",
                 font=("Georgia",17,"bold"), fg=ACCENT, bg=PAGE_BG).pack(anchor="w", pady=(0,4))

        bp = self.SQ * 8 + 36
        self.canvas = tk.Canvas(centre, width=bp, height=bp+4,
                                bg=PAGE_BG, highlightthickness=0)
