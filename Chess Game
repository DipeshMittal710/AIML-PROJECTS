        mf.pack(fill=tk.BOTH, expand=True, padx=4)
        self.move_text = tk.Text(mf, font=("Consolas",9), bg="#fffaf6",
                                 fg="#333", width=26, relief="solid", bd=1,
                                 state="disabled", wrap="word")
        sb = tk.Scrollbar(mf, command=self.move_text.yview)
        self.move_text.configure(yscrollcommand=sb.set)
        self.move_text.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        sb.pack(side=tk.RIGHT, fill=tk.Y)
        self.move_text.tag_configure("wm", foreground="#7a4f32", font=("Consolas",9,"bold"))
        self.move_text.tag_configure("bm", foreground="#333",    font=("Consolas",9))
        self.move_text.tag_configure("nn", foreground="#aaa",    font=("Consolas",9))

        tk.Label(parent, text="Click piece → see legal moves. Type e2e4 or e2 e4.",
