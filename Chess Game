                                   relief="solid", bd=1)
        self.move_entry.pack(side=tk.LEFT, padx=(0,6))
        self.move_entry.bind("<Return>", lambda _: self._play_text_move())
        tk.Button(row, text="Play", font=("Arial",10,"bold"),
                  bg=ACCENT, fg="white", relief="flat", padx=10,
                  command=self._play_text_move).pack(side=tk.LEFT)

